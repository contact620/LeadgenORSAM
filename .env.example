# Serper.dev API (LinkedIn search via Google index)
# Free tier: 2500 queries/month — https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Dropcontact API
DROPCONTACT_API_KEY=your_dropcontact_api_key_here

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Paths
APOLLO_COOKIES_PATH=apollo_cookies.json

# Behavior
REQUEST_DELAY=2.0
HIT_THRESHOLD=50
DROPCONTACT_BATCH_SIZE=50
MAX_LEADS=500
